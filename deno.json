{
  "name": "git-remote-ops",
  "version": "0.1.0",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "bin": {
    "git-remote-ops": "./src/cli.ts"
  },
  "tasks": {
    "check": "deno check src/index.ts src/cli.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test --allow-read tests",
    "test:e2e": "deno test --allow-run --allow-net --allow-read --allow-write --allow-env tests/e2e",
    "test:all": "deno test --allow-run --allow-net --allow-read --allow-write --allow-env tests",
    "verify": "deno fmt --check && deno lint && deno check src/index.ts src/cli.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window"]
  }
}
