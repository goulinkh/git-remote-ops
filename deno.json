{
  "name": "git-remote-ops",
  "version": "0.1.0",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts"
  },
  "bin": {
    "git-remote-ops": "./src/cli.ts"
  },
  "imports": {
    "@std/crypto": "jsr:@std/crypto@^1",
    "@std/encoding/hex": "jsr:@std/encoding@^1/hex",
    "better-result": "npm:better-result@^2"
  },
  "tasks": {
    "check": "deno check src/index.ts src/cli.ts",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "test": "deno test --allow-read src/objects src/pack src/protocol",
    "test:all": "deno test --allow-run --allow-net --allow-read --allow-write --allow-env src",
    "verify": "deno fmt --check && deno lint && deno check src/index.ts src/cli.ts"
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "strict": true,
    "lib": ["deno.window"]
  }
}
